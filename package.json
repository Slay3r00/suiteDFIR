{
    "name": "vdf-tools",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "cd frontend && npm run dev",
        "electron": "cd electron && npm start",
        "dev:electron": "concurrently --raw \"npm run dev\" \"npm run electron\"",
        "install:all": "npm install && cd frontend && npm install && cd ../electron && npm install",
        "build:frontend": "cd frontend && npm run build:static",
        "build:backend": "cd backend && ./build.sh",
        "build:all": "npm run build:backend && npm run build:frontend",
        "package": "cd electron && electron-forge package",
        "build:mac": "./build-mac.sh"
    },
    "workspaces": [
        "frontend"
    ],
    "devDependencies": {
        "@tailwindcss/postcss": "^4.0.0-alpha.25",
        "concurrently": "^8.2.2",
        "tailwindcss": "^4.0.0-alpha.25",
        "wait-on": "^9.0.3"
    }
}