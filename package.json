{
    "name": "vdf-tools",
    "version": "0.1.0",
    "description": "VDF Forensic Tools",
    "author": "VDF Tools",
    "private": true,
    "scripts": {
        "dev": "cd frontend && yarn dev",
        "electron": "cd electron && yarn start",
        "dev:electron": "concurrently --raw \"yarn run dev\" \"yarn run electron\"",
        "install:all": "yarn install && cd frontend && yarn install && cd ../electron && yarn install",
        "build:frontend": "cd frontend && yarn run build",
        "build:backend": "cd backend && ./build.sh",
        "build:all": "yarn run build:backend && yarn run build:frontend",
        "package": "cd electron && yarn electron-builder --dir",
        "build:mac": "scripts/build-mac.sh",
        "build:linux": "scripts/build-linux.sh",
        "build:win": "scripts\\build-win.bat"
    },
    "workspaces": [
        "frontend"
    ],
    "devDependencies": {
        "@tailwindcss/postcss": "^4.0.0-alpha.25",
        "concurrently": "^8.2.2",
        "tailwindcss": "^4.0.0-alpha.25",
        "wait-on": "^9.0.3"
    },
    "dependencies": {
        "get-port": "^7.1.0"
    }
}